# COS202 Simple Mathematical Calculator

print("------ SIMPLE CALCULATOR -------")
print("Operations: +  -  *  /  %  ^")
print("Type OFF to exit")

while True:
    operation = input("Enter operation: ")

    if operation == "OFF":
        print("Calculator switched OFF")
        break

    if operation == "C":
        print("Cleared")
        continue

    num1 = float(input("Enter first number: "))
    num2 = float(input("Enter second number: "))

    if operation == "+":
        print("Result:", num1 + num2)

    elif operation == "-":
        print("Result:", num1 - num2)

    elif operation == "*":
        print("Result:", num1 * num2)

    elif operation == "/":
        if num2 != 0:
            print("Result:", num1 / num2)
        else:
            print("Error: Cannot divide by zero")

    elif operation == "%":
        print("Result:", num1 % num2)

    elif operation == "^":
        print("Result:", num1 ** num2)

    else:
        print("Invalid operation")
