# COS202 CGPA CALCULATOR (Simple Version)

print("----- CGPA CALCULATOR -----")

total_units = 0
total_points = 0

courses = int(input("Enter number of courses: "))

for i in range(courses):
    print(Course {i+1}")

    grade = input("Enter grade (A, B, C, D, E, F): ").upper()
    unit = int(input("Enter course unit: "))

    if grade == "A":
        point = 5
    elif grade == "B":
        point = 4
    elif grade == "C":
        point = 3
    elif grade == "D":
        point = 2
    elif grade == "E":
        point = 1
    else:
        point = 0

    total_units += unit
    total_points += point * unit

cgpa = total_points / total_units

print("------ RESULT ------")
print("Total Units:", total_units)
print("Total Points:", total_points)
print("Your CGPA is:", round(cgpa, 2))
