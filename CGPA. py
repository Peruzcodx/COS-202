print("----- CGPA CALCULATOR -----")

courses = int(input("Number of courses: "))

total_units = 0
total_points = 0

for i in range(courses):
    print("\nCourse", i+1)

    grade = input("ENTER Grade (A-F): ").upper()
    unit = int(input("Enter course units: "))

    if grade == "A":
        point = 5
    elif grade == "B":
        point = 4
    elif grade == "C":
        point = 3
    elif grade == "D":
        point = 2
    elif grade == "E":
        point = 1
    else:
        point = 0

    total_points = total_points + (point * unit)
    total_units = total_units + unit

cgpa = total_points / total_units
print("Total point: ", total_points)
print("Total unit :", total_units)

print("\nCGPA =", round(cgpa, 2))
